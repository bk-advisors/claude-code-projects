  geom_line(
    aes(x = year, y = value,
        linetype = group)
  )`.trim()},{id:"Linewidth",group:"Appearance",value:5,description:(0,a.jsx)("div",{children:(0,a.jsxs)("p",{children:["Controls the ",(0,a.jsx)("b",{children:"thickness of lines"})," in geometries like"," ",(0,a.jsx)("code",{children:"geom_line()"}),".",(0,a.jsx)("br",{}),"Here, we vary the linewidth based on tooth length."]})}),code:`
library(ggplot2)

# note that values are drawn randomly each time
df <- data.frame(
