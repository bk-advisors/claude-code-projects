ame:"text-align: center;",children:(0,s.jsx)("p",{className:"font-bricolage font-medium",children:"Customize legend titles and labels: replace species names with full Latin names, set custom tick marks, and label body mass values with units."})}),(0,s.jsx)("div",{className:"full-bleed flex justify-center my-4",children:(0,s.jsx)("div",{className:"w-full max-w-[1000px]",children:(0,s.jsx)(t.ResponsiveREditor,{initialRCode:`library(ggplot2)
penguins <- read.csv("https://www.ggplot2-uncharted.com/data/palmerpenguins.csv")

ggplot(penguins) +
  aes(x = bill_length_mm, y = bill_depth_mm,
      color = species, size = body_mass_g) +
  geom_point(shape = 16, alpha = .6) +
  theme_light() +
  # adjust labels in color legend
  scale_color_discrete(
    name = "Species:",
    labels = c("Pygoscelis adeliae", "Pygoscelis antarctica", "Pygoscelis papua")
  ) +
  # adjust labels and values in size legend
  scale_size(
    name = "Body mass:",
    range = c(.5, 5),
    breaks = quantile(penguins$body_mass_g, na.rm = TRUE),
    labels = scales::label_number(suffix = " g")
  )`,height:390})})})]}),(0,s.jsxs)(n.TabsContent,{value:"theme",className:"wrapper",children:[(0,s.jsx)("div",{className:"text-align: center;",children:(0,s.jsx)("p",{className:"font-bricolage font-medium",children:"Move and style the legend: place it on top, set labels in monospace, add subtle grey outlines, and position titles above the keys."})}),(0,s.jsx)("div",{className:"full-bleed flex justify-center my-4",children:(0,s.jsx)("div",{className:"w-full max-w-[1000px]",children:(0,s.jsx)(t.ResponsiveREditor,{initialRCode:`library(ggplot2)
penguins <- read.csv("https://www.ggplot2-uncharted.com/data/palmerpenguins.csv")

ggplot(penguins) +
  aes(x = bill_length_mm, y = bill_depth_mm,
      color = species, size = body_mass_g) +
  geom_point(shape = 16, alpha = .6) +
  theme_light() +
  # adjust legend position and style
  theme(
    legend.position = "top",
    legend.title.position = "top",
    legend.text = element_text(family = "monospace"),
    legend.key = element_rect(color = "grey80")
  )`,height:390})})})]}),(0,s.jsxs)(n.TabsContent,{value:"guide",className:"wrapper",children:[(0,s.jsx)("div",{className:"text-align: center;",children:(0,s.jsx)("p",{className:"font-bricolage font-medium",children:"Fine-tune layout and appearance: create a binned guide with modified text for size, larger dots with flipped order for color, and reorder legends."})}),(0,s.jsx)("div",{className:"full-bleed flex justify-center my-4",children:(0,s.jsx)("div",{className:"w-full max-w-[1000px]",children:(0,s.jsx)(t.ResponsiveREditor,{initialRCode:`library(ggplot2)
penguins <- read.csv("https://www.ggplot2-uncharted.com/data/palmerpenguins.csv")

ggplot(penguins) +
  aes(x = bill_length_mm, y = bill_depth_mm,
      color = species, size = body_mass_g) +
  geom_point(shape = 16, alpha = .6) +
  theme_light() +
  # adjust legend order and style each separately
  guides(
    size = guide_bins(
      order = 1,
      theme = theme(legend.text = element_text(family = "monospace"))
    ),
    color = guide_legend(
      reverse = TRUE,
      override.aes = list(size = 5)
    )
  )`,height:390})})})]})]})})]})])}]);