library(dplyr)
library(forcats)

brics <- read.csv("https://www.ggplot2-uncharted.com/data/gapminder-brics.csv")

ggplot(brics, aes(x = year, y = co2_pcap)) +
  geom_line(
    aes(color = fct_reorder(
      country, co2_pcap,
      .fun = last, .desc = TRUE
    )),
    key_glyph = "timeseries"
  ) +
  labs(color = NULL)`.trim(),id:"M2-L5-legend-sort-categories",pkgs:["dplyr","forcats"]},{whyItMatters:(0,s.jsx)(s.Fragment,{children:(0,s.jsxs)("div",{children:[(0,s.jsxs)("p",{children:["Legends for continuous data can take different forms. Choosing a suitable ",(0,s.jsx)("code",{children:"guide"})," helps you communicate the underlying structure of your data more effectively."]}),(0,s.jsxs)("p",{children:["Switching from the default colorbar to a"," ",(0,s.jsx)("b",{children:"colorsteps groups the values into discrete steps"})," ",(0,s.jsx)("u",{children:"in the legend"}),". Since IMDb ratings come on a 1–10 scale, this makes it easier for readers to interpret color ranges as meaningful rating levels — without affecting the smooth color transitions in the heatmap itself."]}),(0,s.jsxs)("p",{children:["(In case you argue that the heatmap colors should be binned as well: simply use the binned scale ",(0,s.jsx)("code",{children:"scale_fill_fermenter()"})," ","instead.)"]})]})}),toDo:(0,s.jsxs)("div",{children:[(0,s.jsxs)("p",{children:["Adjust the colors and legend in the heatmap showing"," ",(0,s.jsx)(n.DatasetPreviewButton,{url:"simpsons_episodes.csv",name:"IMDb ratings for Simpsons episodes"}),"."]}),(0,s.jsxs)("p",{children:["Apply a diverging color palette from the ",(0,s.jsx)("code",{children:"RColorBrewer"})," ","package. Then, convert the default ",(0,s.jsx)("code",{children:"colorbar"})," into a"," ",(0,s.jsx)("code",{children:"colorsteps"}),"guide using the ",(0,s.jsx)("code",{children:"guide"})," argument. Finally, give the legend a clear, human-readable title."]}),(0,s.jsxs)("p",{children:[(0,s.jsx)("u",{children:"Reminder:"})," Continuous ColorBrewer palettes are included in",(0,s.jsx)("code",{children:"ggplot2"})," and can be added with"," ",(0,s.jsx)("code",{children:"scale_color_distiller()"}),"or ",(0,s.jsx)("code",{children:"scale_fill_distiller()"}),"."]}),(0,s.jsxs)("p",{children:[(0,s.jsx)("u",{children:(0,s.jsx)("b",{children:"Bonus Task:"})})," ","Move the x-axis to the top so readers encounter that information first — a small tweak that can subtly guide the viewer’s attention."]})]}),practiceSandbox:`library(ggplot2)
simpsons <- read.csv("https://www.ggplot2-uncharted.com/data/simpsons_episodes.csv")

ggplot(data = simpsons, aes(x = factor(number_in_season), y = factor(season))) +
  geom_tile(aes(fill = imdb_rating)) +
  scale_y_discrete(limits = rev) +
  labs(x = "Episode", y = "Season") +
  theme_minimal() +
  theme(panel.grid = element_blank())
`.trim(),solutionSandbox:`library(ggplot2)
simpsons <- read.csv("https://www.ggplot2-uncharted.com/data/simpsons_episodes.csv")

ggplot(data = simpsons, aes(x = factor(number_in_season), y = factor(season))) +
  geom_tile(aes(fill = imdb_rating)) +
  scale_y_discrete(limits = rev) +
  # modify how fill is shown
  scale_fill_distiller(
    palette = "PuOr", # change color gradient
    direction = 1,    # ... and flip it
    na.value = "white",
    name = "IMDb rating", # add clean label
    guide = guide_colorsteps() # create binned legend
  ) +
  # move x-axis to the top (bonus)
  scale_x_discrete(position = "top") +
  labs(x = "Episode", y = "Season") +
  theme_minimal() +
  theme(panel.grid = element_blank())
`.trim(),id:"M2-L5-legend-guide-colorsteps"},{whyItMatters:(0,s.jsx)(s.Fragment,{children:(0,s.jsxs)("div",{children:[(0,s.jsx)("p",{children:"Sometimes the default legend key sizes aren’t ideal. They can be too narrow or short to read comfortably — or may simply not fit your design."}),(0,s.jsxs)("p",{children:["Adjusting the width and height with",(0,s.jsx)("b",{children:(0,s.jsx)("code",{children:"legend.key.size"})})," ","which applies the same value to both,"," ",(0,s.jsxs)("b",{children:["or individually with ",(0,s.jsx)("code",{children:"legend.key.width"})," and"," ",(0,s.jsx)("code",{children:"legend.key.height"})]}),", gives you precise control over how the keys appear."]}),(0,s.jsxs)("p",{children:["These values require the ",(0,s.jsx)("code",{children:"unit()"})," function to specify the measurement. This approach works not only for discrete keys but also for gradient legends like colorbars or colorsteps."]})]})}),toDo:(0,s.jsxs)("div",{children:[(0,s.jsx)("p",{children:"The legend shows lines for each group, but they may be hard to see alongside the points."}),(0,s.jsxs)("p",{children:[(0,s.jsx)("b",{children:"Find the legend option that controls the key width"})," and increase it so the lines are depicted clearly."]}),(0,s.jsxs)("p",{children:[(0,s.jsx)("u",{children:(0,s.jsx)("b",{children:"Hint:"})})," ","You need to pass the width as a number with an associated unit, like"," ",(0,s.jsx)("code",{children:'unit(4, "lines")'}),"."]}),(0,s.jsxs)("p",{children:[(0,s.jsx)("u",{children:(0,s.jsx)("b",{children:"Bonus Task:"})})," ","In addition, increase the spacing between the legend keys so that they're clearly spearated."]})]}),practiceSandbox:`library(ggplot2)

df <- data.frame(
  group = rep(c("A", "B", "C"), each = 5),
  step = rep(1:5, 3),
  value = c(4, 5, 8, 2, 6, 1, 4, 5, 4, 9, 0, 3, 2, 5, 5)
)

ggplot(df) +
  aes(x = step, y = value, color = group) +
  geom_line(linewidth = 1.5) +
  geom_point(size = 5) +
  theme_minimal(base_size = 16) +
  labs(color = NULL) +
  theme(
    legend.position = "inside",
    legend.position.inside = c(.05, .99),
    legend.justification = c(0, 1)
  )
  `.trim(),solutionSandbox:`library(ggplot2)

df <- data.frame(
  group = rep(c("A", "B", "C"), each = 5),
  step = rep(1:5, 3),
  value = c(4, 5, 8, 2, 6, 1, 4, 5, 4, 9, 0, 3, 2, 5, 5)
)

ggplot(df) +
  aes(x = step, y = value, color = group) +
  geom_line(linewidth = 1.5) +
  geom_point(size = 5) +
  labs(color = NULL) +
  theme_minimal(base_size = 16) +
  theme(
    legend.position = "inside",
    legend.position.inside = c(.05, .99),
    legend.justification = c(0, 1),
    legend.key.width = unit(4, "lines"),
    legend.key.spacing.y = unit(.5, "lines") # bonus
