penguins <- read.csv("https://www.ggplot2-uncharted.com/data/palmerpenguins.csv")

ggplot(penguins) +
  aes(x = flipper_length_mm, y = bill_length_mm) +
  geom_point(
    aes(shape = body_mass_g > 5000,
        color = species),
    size = 4
  ) +
  scale_color_discrete(
    guide = guide_legend(
      override.aes = list(shape = 1)
    ),
    name = "Species:"
  ) +
  scale_shape_manual(
    values = c(1, 19),
    guide = "none"
  ) +
  theme_minimal(base_size = 14) +
  theme(legend.position = "top")
`.trim(),id:"M2-L5-legend-override-aes"},{whyItMatters:(0,s.jsx)(s.Fragment,{children:(0,s.jsxs)("div",{children:[(0,s.jsx)("p",{children:"Using color to distinguish many categories is tricky — often a maximum of 5–8 qualitative colors is recommended, depending on whom you ask."}),(0,s.jsx)("p",{children:"Sorting the legend so that the entries follow the order of the lines at the end of the timesieres helps readers immediately connect each color to its line. This is often a good idea in general, not just when there are many groups, because it reduces cognitive load and makes the chart easier to interpret."})]})}),toDo:(0,s.jsxs)("div",{children:[(0,s.jsxs)("p",{children:["The BRICS CO₂ emissions over time are plotted using lines colored by"," ",(0,s.jsx)("code",{children:"country"}),". With 10 countries, so the use of a color encoding is not ideal. (But maybe our boss told us to do so...)"]}),(0,s.jsxs)("p",{children:["Let's make it easier for readers to match colors to countries:"," ",(0,s.jsx)("b",{children:"sort the legend so that the orders corresponds to the order of the lines, the per-capita emissions in the most recent year."})," ","Use"," ",(0,s.jsxs)("b",{children:[(0,s.jsx)("code",{children:"fct_reorder()"})," from the ",(0,s.jsx)("code",{children:"forcats"})," package"]}),"to achieve that."]}),(0,s.jsxs)("p",{children:["You can call the ",(0,s.jsx)("code",{children:"fct_reorder()"})," directly in"," ",(0,s.jsx)("code",{children:"aes()"})," — however, the function is reflected in the legend as well. Here, we can ",(0,s.jsx)("b",{children:"omit the legend title"})," as the category names are self-explanatory. Adjust the label accordingly."]}),(0,s.jsxs)("p",{children:[(0,s.jsx)("b",{children:(0,s.jsx)("u",{children:"Hint:"})})," ","The ",(0,s.jsx)("code",{children:"fct_reorder()"})," from the ",(0,s.jsx)("code",{children:"forcats"})," function is handy to reorder factors (here ",(0,s.jsx)("code",{children:"country"})," (here"," ",(0,s.jsx)("code",{children:"co2_pcap"}),"). Using ",(0,s.jsx)("code",{children:".fun = last"})," sorts by the most recent value, and ",(0,s.jsx)("code",{children:".desc = TRUE"})," ensures the legend matches the line order from high to low."]})]}),practiceSandbox:`library(ggplot2)
library(dplyr)
library(forcats)

brics <- read.csv("https://www.ggplot2-uncharted.com/data/gapminder-brics.csv")

