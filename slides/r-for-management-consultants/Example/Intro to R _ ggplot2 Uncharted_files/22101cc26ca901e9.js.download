ggplot(gapminder) +
  aes(
    x = gdp_pcap,
    y = life_exp,
    fill = continent,
    size = pop
  ) +
  geom_point(shape = 21, alpha = .7) +
  scale_fill_brewer(palette = "Dark2") +
  scale_x_log10(
    labels = scales::label_number(suffix = " Int$")
  )
`.trim(),z=`
labs(
  x = "GDP per capita (price and inflation adjusted)",
  y = "Life Expectancy (years)",
  fill = "Continent:",
  size = "Population:"
)
`.trim(),T=`
scale_size_area(
  max_size = 18, # adjust bubble sizes
  breaks = c(.001, .01, .1, .25, .5, 1)*10^9, # change bubble steps
  labels = c(paste(c(1, 10, 100, 250, 500), "Million"), "1 Billion") # polish key labels
)
`.trim(),C=`
  theme_light(base_family = "Roboto") +
  theme(
    legend.position = "top",                    # move legends to the top
    legend.box.just = "left",                   # left-align both legends
    legend.justification = "left",              # left-align legends with panel
    legend.box = "vertical",                    # place legends below each other
    legend.title.position = "top",              # place title above the dots
    legend.text.position = "bottom",            # place labels below dots
    legend.title = element_text(face = "bold"), # style legend titles
    legend.key.width = unit(.08, "npc"),        # increase key width
    legend.spacing = unit(.2, "lines")          # decrease spacing between legends
  )
`.trim(),E=`
guides(
  fill = guide_legend(
    order = 1,                                # place fill legend first
    override.aes = list(size = 5)             # increase dot size
  ),
  size = guide_legend(
    theme = theme(
      legend.text = element_text(family = "Roboto Mono"), # use tabular font
      legend.key.width = unit(.14, "npc")     # increase space for key labels
    ),
    nrow = 1                                  # prohibit wrapping into two lines
  )
)
