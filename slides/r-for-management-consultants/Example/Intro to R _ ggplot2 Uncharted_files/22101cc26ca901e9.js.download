set.seed(1)
df <- data.frame(
  x = c(rnorm(500, 1), rnorm(500, 3), rnorm(500, 5)),
  y = c(rnorm(500, 1), rnorm(500, 3), rnorm(500, 5)),
  group = rep(c("A", "B", "C"), each = 500)
)

ggplot(df) +
  aes(x = x, y = y, color = group) +
  geom_point(size = .8, alpha = .7) +
  theme_minimal(base_size = 14)
  `.trim(),solutionSandbox:`library(ggplot2)

set.seed(1)
df <- data.frame(
  x = c(rnorm(500, 1), rnorm(500, 3), rnorm(500, 5)),
  y = c(rnorm(500, 1), rnorm(500, 3), rnorm(500, 5)),
  group = rep(c("A", "B", "C"), each = 500)
)

ggplot(df) +
  aes(x = x, y = y, color = group) +
  geom_point(size = .8, alpha = .7) +
  guides(
    color = guide_legend(
      override.aes = list(size = 4)
    )
  ) +
  theme_minimal(base_size = 14)
  `.trim(),id:"M2-L5-legend-bigger-symbols"},{whyItMatters:(0,s.jsx)(s.Fragment,{children:(0,s.jsxs)("div",{children:[(0,s.jsxs)("p",{children:["Legends are helpful, but they can also become distracting. In presentations or multi-step storyboards, you often want"," ",(0,s.jsx)("b",{children:"consistency when building up plots step by step"}),". That way, your audience won’t be thrown off by a legend that keeps shifting or competing for attention while you talk through the graphic."]}),(0,s.jsxs)("p",{children:["To remove a specific legend, address the corresponding scale directly with",(0,s.jsx)("code",{children:'guide = "none"'}),". This allows you to keep your plot clean while giving you"," ",(0,s.jsx)("b",{children:"full control over which guides remain visible"}),"."]})]})}),toDo:(0,s.jsxs)("div",{children:[(0,s.jsxs)("p",{children:["Let's imagine this chart is part of a presentation with a narrative arc. You have introduced the scatterplot showing the"," ",(0,s.jsx)(n.DatasetPreviewButton,{url:"palmerpenguins.csv",name:"palmerpenguins"})," ","data of bill and flipper lengths for the three different species."]}),(0,s.jsxs)("p",{children:["Now, we highlight the penguins weight 5 kilogram or more by turning hollow circles into solid dots by mapping a threshold of"," ",(0,s.jsx)("code",{children:"body_mass_g"})," to ",(0,s.jsx)("code",{children:"shape"}),"."]}),(0,s.jsxs)("p",{children:["Your task: As the legend is too crowded (and also should stay put across slides)"," ",(0,s.jsx)("b",{children:"remove the size legend — but keep the species legend!"})]}),(0,s.jsxs)("p",{children:[(0,s.jsx)("b",{children:(0,s.jsx)("u",{children:"Hint:"})})," ","You need to address the respective scale and add"," ",(0,s.jsx)("code",{children:'guide = "none"'}),"."]})]}),practiceSandbox:`library(ggplot2)
penguins <- read.csv("https://www.ggplot2-uncharted.com/data/palmerpenguins.csv")

ggplot(penguins) +
  aes(x = flipper_length_mm, y = bill_length_mm) +
  geom_point(
    aes(shape = body_mass_g > 5000,
        color = species),
    size = 4
  ) +
  scale_shape_manual(values = c(1, 19)) +
  theme_minimal(base_size = 14) +
  theme(legend.position = "top")
`.trim(),solutionSandbox:`library(ggplot2)
penguins <- read.csv("https://www.ggplot2-uncharted.com/data/palmerpenguins.csv")

ggplot(penguins) +
  aes(x = flipper_length_mm, y = bill_length_mm) +
  geom_point(
    aes(shape = body_mass_g > 5000,
        color = species),
    size = 4
  ) +
  scale_shape_manual(
    values = c(1, 19),
    guide = "none" # remove size legend
  ) +
  theme_minimal(base_size = 14) +
  theme(legend.position = "top")
